<?xml version="1.0" encoding="UTF-8"?>
<hazelcast xmlns="http://www.hazelcast.com/schema/config"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://www.hazelcast.com/schema/config
           http://www.hazelcast.com/schema/config/hazelcast-config-5.5.xsd">

    <instance-name>devops-cache</instance-name>

    <network>
        <join>
            <auto-detection enabled="false"/>
            <multicast enabled="false"/>
        </join>
    </network>

    <!-- Cache for cluster status (pods, deployments, nodes) - TTL 15s -->
    <map name="clusterStatus">
        <time-to-live-seconds>15</time-to-live-seconds>
        <max-idle-seconds>30</max-idle-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="100"/>
    </map>

    <!-- Cache for command execution history - TTL 10s -->
    <map name="executionHistory">
        <time-to-live-seconds>10</time-to-live-seconds>
        <max-idle-seconds>20</max-idle-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="50"/>
    </map>

    <!-- Cache for available commands (rarely changes) - TTL 5 min -->
    <map name="availableCommands">
        <time-to-live-seconds>300</time-to-live-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="20"/>
    </map>

    <!-- Cache for resource names (pod/ns lists) - TTL 20s -->
    <map name="resourceNames">
        <time-to-live-seconds>20</time-to-live-seconds>
        <max-idle-seconds>40</max-idle-seconds>
        <eviction eviction-policy="LRU" max-size-policy="PER_NODE" size="200"/>
    </map>

</hazelcast>
